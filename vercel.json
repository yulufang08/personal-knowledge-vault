{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "env": {
    "VITE_API_URL": {
      "description": "Backend API URL",
      "required": true
    },
    "NODE_ENV": "production"
  },
  "regions": ["sfo1", "sin1"],
  "functions": {
    "api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/api/:path*",
      "destination": "${VITE_API_URL}/api/:path*"
    }
  ]
}
